#!/usr/bin/env bash
PATH="/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin"

SOCKET="$HOME/.mpv-audio.sock"

# Check if socket exists and is still connected
if [ -S "$SOCKET" ]; then
  # Try to connect - if it fails, socket is stale
  if printf '{ "command": ["get_property", "idle"] }\n' | socat -t 0.1 - "UNIX-CONNECT:$SOCKET" >/dev/null 2>&1; then
    # Socket is alive and connected
    exit 0
  else
    # Stale socket - remove it
    rm -f "$SOCKET"
  fi
fi

nohup /opt/homebrew/bin/mpv \
  --no-video \
  --idle=yes \
  --keep-open=yes \
  --input-ipc-server="$SOCKET" \
  --force-window=no \
  >/dev/null 2>&1 &
