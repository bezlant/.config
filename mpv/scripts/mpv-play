#!/usr/bin/env bash
PATH="/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin"
set -euo pipefail

SOCKET="$HOME/.mpv-audio.sock"

# Check if daemon is running
if [ ! -S "$SOCKET" ]; then
  # No socket - start daemon
  "$HOME/.local/bin/mpv-daemon"
  sleep 1
elif ! printf '{ "command": ["get_property", "idle"] }\n' | socat -t 0.1 - "UNIX-CONNECT:$SOCKET" >/dev/null 2>&1; then
  # Stale socket - remove and restart daemon
  rm -f "$SOCKET"
  "$HOME/.local/bin/mpv-daemon"
  sleep 1
fi

# no args = toggle pause
if [ "$#" -eq 0 ]; then
  printf '{ "command": ["cycle", "pause"] }\n' \
    | socat - UNIX-CONNECT:"$SOCKET"
  exit 0
fi

for f in "$@"; do
  f="${f/#\~/$HOME}"
  f="$(cd "$(dirname "$f")" && pwd)/$(basename "$f")"

  # force unpause, then load
  printf '{ "command": ["set_property", "pause", false] }\n' \
    | socat - UNIX-CONNECT:"$SOCKET"

  printf '{ "command": ["loadfile", "%s", "replace"] }\n' "$f" \
    | socat - UNIX-CONNECT:"$SOCKET"
done
