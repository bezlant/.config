#!/usr/bin/env bash
PATH="/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin"

SOCKET="$HOME/.mpv-audio.sock"

# Check if socket exists
if [ ! -S "$SOCKET" ]; then
  exit 0
fi

# Try to send stop command - if it fails, remove stale socket
if ! printf '{ "command": ["stop"] }\n' | socat -t 0.1 - "UNIX-CONNECT:$SOCKET" >/dev/null 2>&1; then
  # Stale socket - clean it up
  rm -f "$SOCKET"
fi
